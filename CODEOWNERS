# Sibling project — out of scope for the scenarios authors but kept under joint
# review so a stray cross-project edit gets caught.
/light-manager/  @clement-raussin @qrodic

# scenarios/ — per-UC ownership boundary (NFR-008)
/scenarios/uc1/  @clement-raussin
/scenarios/uc2/  @qrodic
/scenarios/uc3/  @clement-raussin
/scenarios/uc4/  @clement-raussin @qrodic

